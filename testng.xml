<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="HybridSuite" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="API Tests">
        <packages><package name="tests.api"/></packages>
    </test>

    <test name="UI Tests - Chrome">
        <parameter name="browser" value="chrome"/>
        <packages><package name="tests.ui"/></packages>
    </test>

    <test name="Integration Tests">
        <parameter name="browser" value="chrome"/>
        <packages><package name="tests.integration"/></packages>
    </test>
</suite>